#!/bin/bash

STAGED_RUBY=()
STAGED_TS=()
while IFS= read -r -d '' file; do
  case "$file" in
    *.rb) STAGED_RUBY+=("$file") ;;
    *.ts|*.tsx) STAGED_TS+=("$file") ;;
  esac
done < <(git diff --cached --name-only -z --diff-filter=ACM)

if [ ${#STAGED_RUBY[@]} -eq 0 ] && [ ${#STAGED_TS[@]} -eq 0 ]; then
  exit 0
fi

FAILED=0

if [ ${#STAGED_RUBY[@]} -gt 0 ]; then
  if command -v bundle &>/dev/null && bundle exec rubocop --version &>/dev/null 2>&1; then
    bundle exec rubocop "${STAGED_RUBY[@]}" || FAILED=1
  elif command -v rubocop &>/dev/null; then
    rubocop "${STAGED_RUBY[@]}" || FAILED=1
  fi
fi

if [ ${#STAGED_TS[@]} -gt 0 ]; then
  if command -v npm &>/dev/null; then
    npm exec --no -- eslint "${STAGED_TS[@]}" || FAILED=1
  elif command -v yarn &>/dev/null; then
    yarn eslint "${STAGED_TS[@]}" || FAILED=1
  fi
fi

exit $FAILED
